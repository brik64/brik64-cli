PC l6_cli_materialization_contract {
    fn l6_cli_materialization_contract(
        pcd_inputs_hash_bound,
        l6plus_materializer_accepts_contract,
        generated_artifact_hash_bound,
        package_hash_bound,
        release_manifest_hash_bound
    ) {
        if (pcd_inputs_hash_bound == 0) {
            return 0;
        }
        if (l6plus_materializer_accepts_contract == 0) {
            return 0;
        }
        if (generated_artifact_hash_bound == 0) {
            return 0;
        }
        if (package_hash_bound == 0) {
            return 0;
        }
        if (release_manifest_hash_bound == 0) {
            return 0;
        }
        return 1;
    }
}
