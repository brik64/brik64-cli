  "files": [
    "src",
    "pcd",
    "docs",
    "evidence",
    "packaging",
    "README.md",
    "LICENSE",
    "NOTICE",
    "SECURITY.md",
    "CONTRIBUTING.md",
    ".brik/manifest.json"
  ]
