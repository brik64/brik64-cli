{
  "name": "@brik64/cli",
  "version": "0.1.0-beta.5",
  "private": true,
  "description": "BRIK64 CLI public beta for local PCD workflows, bounded evidence review, and claim-safe project scaffolding.",
  "homepage": "https://brik64.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/brik64/brik64-cli.git"
  },
  "bugs": {
    "url": "https://github.com/brik64/brik64-cli/issues"
  },
  "license": "SEE LICENSE IN LICENSE",
  "bin": {
    "brik": "src/brik.js"
  },
  "scripts": {
    "test": "bash tests/smoke.sh",
    "build:beta5:candidate": "node scripts/build-beta5-candidate.js",
    "gate:beta5:release-surface": "node scripts/beta5-release-surface-gate.js",
    "gate:beta5:release-surface:release": "node scripts/beta5-release-surface-gate.js --release",
    "gate:beta5:sdk-sync": "node scripts/beta5-sdk-sync-gate.js",
    "gate:beta5:skills-sync": "node scripts/beta5-skills-sync-gate.js",
    "gate:beta5:docs-web-sync": "node scripts/beta5-docs-web-sync-gate.js",
    "gate:beta5:marketplace-packages": "node scripts/beta5-marketplace-package-gate.js",
    "preflight:beta5:publication": "node scripts/beta5-publication-preflight.js",
    "audit:beta5:adversarial": "node scripts/beta5-adversarial-audit.js",
    "gate:beta5:local-completion": "node scripts/beta5-local-completion-gate.js",
    "smoke:beta5:cross-platform": "node scripts/beta5-cross-platform-smoke.js",
    "sign:beta5:checksums": "node scripts/beta5-release-checksums.js",
    "package:beta5:local": "node scripts/build-beta5-package.js",
    "smoke:beta5:package": "node scripts/beta5-package-smoke.js",
    "package:beta5:l4-runtime": "node scripts/package-l4-runtime.js",
