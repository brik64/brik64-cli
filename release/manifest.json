  "releaseNotes": [
    {
      "type": "added",
      "surface": "cli",
      "text": "Adds local import graph diagnostics for PCD files that use transitive same-directory imports."
    },
    {
      "type": "added",
      "surface": "cli",
      "text": "Adds literal i64 compile-time constants for supported PCD programs, including bounded repeat counts."
    },
    {
      "type": "added",
      "surface": "cli",
      "text": "Adds brik64 explain with human and JSON diagnostics for parser, import, constant, and type checks."
    },
    {
      "type": "added",
      "surface": "cli",
      "text": "Adds brik64 lock to write local PCD, AST, import graph, and constant hashes into brik64.lock.json."
    },
    {
      "type": "added",
      "surface": "cli",
      "text": "Adds local telemetry status and explain commands while keeping telemetry disabled by default."
    },
    {
      "type": "added",
      "surface": "cli",
      "text": "Adds feedback dry-run and redacted local error-report inspection commands."
    },
    {
      "type": "changed",
      "surface": "cli",
      "text": "Improves local diagnostics for import cycles, invalid constants, and local error capture without sending raw source or PCD content."
    }
