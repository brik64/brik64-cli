  "releaseNotes": [
    {
      "type": "added",
      "surface": "cli",
      "text": "Adds typed i64 function parameters and return annotations for supported PCD programs."
    },
    {
      "type": "added",
      "surface": "cli",
      "text": "Adds bounded list and map expressions for supported local PCD emission."
    },
    {
      "type": "added",
      "surface": "cli",
      "text": "Adds bounded repeat loops with a fixed maximum iteration count."
    },
    {
      "type": "added",
      "surface": "cli",
      "text": "Adds direct same-directory PCD imports and generated helper functions in emitted TypeScript, Rust, and Python outputs."
    },
    {
      "type": "added",
      "surface": "cli",
      "text": "Adds package scaffolds for generated TypeScript, Rust, and Python projects when brik64 emit is used with tests."
    },
    {
      "type": "added",
      "surface": "cli",
      "text": "Adds actionable brik64 doctor diagnostics with stable JSON output for CI."
    },
    {
      "type": "changed",
      "surface": "cli",
      "text": "Improves parser failures for unsupported calls, invalid imports, malformed collection expressions, and unsupported loop forms."
    },
    {
      "type": "changed",
      "surface": "cli",
      "text": "Keeps cloud verification and cloud polymerization entitlement-gated while local workflows remain available by default."
    }
  ],
