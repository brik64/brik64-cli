    {
      "type": "added",
      "surface": "pcd",
      "text": "Adds bounded domain declarations for parameter ranges, invariants, conditional domains, and technical-sheet parameters."
    },
    {
      "type": "added",
      "surface": "cli",
      "text": "Adds domain inspect, validate, sheet, and add commands for bounded PCD workflows."
    },
    {
      "type": "changed",
      "surface": "certify",
      "text": "Requires complete bounded domain contracts by default for local candidate certificates."
    },
    {
      "type": "changed",
      "surface": "emit",
      "text": "Generated TypeScript, Python, and Rust outputs now include domain contract hashes and fail-closed precondition checks."
    },
    {
      "type": "changed",
      "surface": "polymerize",
