  "releaseNotes": [
    {
      "type": "added",
      "surface": "pcd",
      "text": "Adds i32 parameters and return annotations for supported PCD functions while keeping i64 support."
    },
    {
      "type": "changed",
      "surface": "cli",
      "text": "Clarifies emit output behavior so --out can write either a target directory or an exact output file for supported targets."
    },
    {
      "type": "changed",
      "surface": "cli",
      "text": "Improves local and managed routing boundaries for verify, polymerize, login, logout, and account status."
    },
    {
      "type": "added",
      "surface": "cli",
      "text": "Keeps opt-in telemetry, redacted feedback previews, and local error reports disabled from network transfer unless explicitly enabled and sent."
    },
    {
      "type": "added",
      "surface": "web",
      "text": "Adds release download observability requirements for CLI and SDK routes so public beta installs can be reviewed in the private metrics panel."
    }
